# Base URL of the SCGS backend API. Copy this file to `.env` and set the value
# to a URL reachable from wherever the app runs. Must start with EXPO_PUBLIC_ so
# Expo inlines it into the client bundle.
#
#   - Physical device / Expo Go: use the deployed HTTPS tunnel URL
#       EXPO_PUBLIC_API_URL=https://three-superior-arc-chief.trycloudflare.com
#   - Android emulator:        EXPO_PUBLIC_API_URL=https://three-superior-arc-chief.trycloudflare.com
#   - iOS simulator / web:     EXPO_PUBLIC_API_URL=https://three-superior-arc-chief.trycloudflare.com
#
# If unset, src/api/config.ts falls back to a sensible per-platform default.
EXPO_PUBLIC_API_URL=https://three-superior-arc-chief.trycloudflare.com
