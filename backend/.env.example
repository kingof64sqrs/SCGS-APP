# MongoDB connection string.
# The Dockerised MongoDB has auth enabled, so include credentials + authSource:
#   mongodb://<user>:<password>@<host>:27017/?authSource=admin
MONGODB_URI=mongodb://admin:StrongPassword123@127.0.0.1:27017/?authSource=admin
DB_NAME=scgs
PORT=4000

# Admin panel key — sign in at http://<host>:<port>/admin with this value.
ADMIN_KEY=scgs-admin

# Secret used to sign member login tokens (change to any random string).
TOKEN_SECRET=scgs-dev-secret-change-me
